{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Program",
      "program": "${file}",
      "request": "launch",
      "skipFiles": ["<node_internals>/**"],
      "type": "node"
    },
    {
      "name": "PowerShell: Launch Current File",
      "type": "PowerShell",
      "request": "launch",
      "script": "${file}",
      "args": [
        "-Handler",
        "RoboCopy",
        "-Destination", "F:\\Program",
        "\"D:\\Programming\\Programs\\VsCode\"",
        "\"D:\\Programming\\Programs\\Postman\"",
        "\"D:\\Programming\\Programs\\Python\"",
        "\"D:\\Programming\\Programs\\Reverse Engineering\""
      ]
    }
  ]
}
